# ============================================================
# TrendRadar 环境变量配置示例
# ============================================================
# 使用方法:
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 填入你的实际配置值
#   3. .env 文件已在 .gitignore 中，不会被提交到 Git
# ============================================================

# ============================================================
# AI 配置
# ============================================================
# DeepSeek API Key (必填，用于 AI 分析和翻译)
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_ANALYSIS_ENABLED=true
AI_MODEL=deepseek/deepseek-v4-flash
# AI_API_BASE=https://api.deepseek.com  # 可选，使用自定义 API 端点

# ============================================================
# OSS 远程存储配置 (可选，用于数据持久化)
# ============================================================
# 阿里云 OSS 配置
S3_BUCKET_NAME=trendradar-data
S3_ACCESS_KEY_ID=LTAI5tXXXXXXXXXXXXXX
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_ENDPOINT_URL=https://oss-cn-hangzhou.aliyuncs.com
S3_REGION=cn-hangzhou

# ============================================================
# 通知渠道配置 (可选，至少配置一个)
# ============================================================

# 企业微信机器人
# WEWORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx
# WEWORK_MSG_TYPE=markdown  # 或 text

# Telegram Bot
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=your-chat-id

# 钉钉机器人
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx

# 飞书机器人
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 邮件通知
# EMAIL_FROM=sender@example.com
# EMAIL_PASSWORD=your-email-password
# EMAIL_TO=receiver@example.com
# EMAIL_SMTP_SERVER=smtp.example.com
# EMAIL_SMTP_PORT=587

# Ntfy 推送
# NTFY_TOPIC=your-topic
# NTFY_SERVER_URL=https://ntfy.sh
# NTFY_TOKEN=your-token

# Bark 推送
# BARK_URL=https://api.day.app/your-key

# Slack Webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# 通用 Webhook
# GENERIC_WEBHOOK_URL=https://your-webhook-url.com
# GENERIC_WEBHOOK_TEMPLATE={"text": "{{content}}"}
